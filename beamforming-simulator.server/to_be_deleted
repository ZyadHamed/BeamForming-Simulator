# These Pydantic models are purely for HTTP serialisation/validation.
# They mirror the domain value objects (RadarWaveform, RadarDetectionConfig,
# RadarEnvironment) but are intentionally separate so the API contract is
# decoupled from internal physics class structure.

class RadarSetupRequest(BaseModel):
    """
    Sent once when the radar mode loads, or whenever the array or waveform
    configuration changes.  Target positions are supplied per-scan, not here.

    Array parameters (7 controllable parameters per the spec)
    ----------------------------------------------------------
    num_elements     : number of array elements           (beam width control)
    element_spacing  : inter-element spacing, mm          (grating lobe control)
    frequency_mhz    : carrier frequency, MHz             (range / resolution)
    geometry         : 'linear' | 'curved' | 'phased'
    apodization      : window function for side-lobe reduction
    snr              : simulation SNR applied to beam patterns, dB  (0–1000)
    steering_angle   : initial boresight, degrees

    Waveform parameters (encapsulated as RadarWaveform inside the scenario)
    -----------------------------------------------------------------------
    pt_dbm           : peak transmit power, dBm
                         50 dBm =   100 W  (short-range / airborne)
                         70 dBm =  10 kW   (default, S-band search radar)
                         90 dBm =   1 GW   (long-range surveillance)
    prf_hz           : pulse repetition frequency, Hz
                       max unambiguous range = c / (2·PRF)
    pulse_width_us   : pulse width, µs;  range resolution = c·τ/2

    Environment parameters (encapsulated as RadarEnvironment)
    ----------------------------------------------------------
    noise_floor_dbm  : receiver thermal noise, dBm  (typically −100 to −110)
    clutter_floor_dbm: peak ground-clutter at 1 km reference range, dBm
                       (set to −200 to disable; set to −60 for urban clutter)
    clutter_range_exp: clutter fall-off, dB/decade  (−20 surface, −40 volume)

    Detector parameters (encapsulated as RadarDetectionConfig)
    ----------------------------------------------------------
    cfar_guard_cells : guard cells each side of the CUT in CA-CFAR
    cfar_ref_cells   : reference cells each side in CA-CFAR
    cfar_pfa         : desired probability of false alarm (e.g. 1e-4)
    """
    # ── Array geometry ─────────────────────────────────────────────────────
    num_elements     : int
    element_spacing  : float                                          # mm
    frequency_mhz    : float                                          # MHz
    geometry         : Literal['linear', 'curved', 'phased'] = 'linear'
    curvature_radius : float  = 60.0
    steering_angle   : float  = 0.0
    focus_depth      : float  = 0.0
    snr              : float  = 60.0                                  # dB, 0–1000
    apodization      : Literal['none', 'hanning', 'hamming',
                                'blackman', 'kaiser', 'tukey'] = 'none'
    elements         : List[ElementInput] = []

    # ── Waveform (maps to RadarWaveform value object) ──────────────────────
    pt_dbm           : float  = 70.0
    prf_hz           : float  = 1000.0
    pulse_width_us   : float  = 1.0

    # ── Environment (maps to RadarEnvironment) ─────────────────────────────
    noise_floor_dbm  : float  = -100.0
    clutter_floor_dbm: float  = -200.0
    clutter_range_exp: float  = -20.0

    # ── Detector (maps to RadarDetectionConfig) ────────────────────────────
    cfar_guard_cells : int    = 2
    cfar_ref_cells   : int    = 8
    cfar_pfa         : float  = 1e-4


class RadarTargetDTO(BaseModel):
    """
    A single target in the radar scene (up to 5 per the spec).

    Coordinates are in metres, North-up convention:
        x_m = East component  (right on PPI)
        y_m = North component (up   on PPI)

    velocity_m_s : radial component toward the radar (positive = approaching).
    rcs_sqm      : radar cross section, m².  Controls detection range and blip
                   size.  Larger bodies have higher RCS:
                       person ~1 m², car ~10 m², aircraft ~2–20 m².
    """
    target_id   : str
    x_m         : float
    y_m         : float
    velocity_m_s: float = 0.0
    rcs_sqm     : float


class RadarScanRequest(BaseModel):
    """
    Parameters for a single PPI sector scan request.

    Angles are clockwise-from-North degrees (matching the target bearing
    convention).  A full 360° electronic sweep:
        start_angle=0, end_angle=360, num_lines=360

    A narrow-beam size-estimation scan:
        start_angle=-10, end_angle=10, num_lines=40 (finer angular step)

    num_range_bins  : range-profile depth returned per beam line (default 128).
    max_range_m     : instrumented range gate in metres.
    """
    start_angle    : float
    end_angle      : float
    num_lines      : int   = 36
    max_range_m    : float = 150_000.0
    num_range_bins : int   = 128
    targets        : List[RadarTargetDTO]


